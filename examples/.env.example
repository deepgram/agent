# Copy to examples/.env and fill in your key, or use a 1Password reference.
#
# Plain key:
#   DEEPGRAM_API_KEY=your_deepgram_api_key_here
#
# 1Password (run via `bun dev:examples` which calls `op run --env-file`):
#   DEEPGRAM_API_KEY=op://Personal/Deepgram API key/credential
DEEPGRAM_API_KEY=op://Personal/Deepgram API key/credential
