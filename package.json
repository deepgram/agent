{
  "name": "@deepgram/voice-agent-monorepo",
  "private": true,
  "workspaces": [
    "packages/sdk",
    "packages/widget",
    "examples"
  ],
  "packageManager": "bun@1.3.13",
  "scripts": {
    "build": "bun run --filter '@deepgram/agents' --filter '@deepgram/agents-widget' build",
    "dev": "bun run --filter '@deepgram/agents' --filter '@deepgram/agents-widget' dev",
    "dev:examples": "op run --env-file examples/.env -- bun run --cwd examples dev",
    "typecheck": "bun run --filter '@deepgram/agents' --filter '@deepgram/agents-widget' typecheck",
    "test": "bun run --filter '@deepgram/agents' --filter '@deepgram/agents-widget' test"
  },
  "overrides": {
    "brace-expansion": "5.0.5"
  }
}
