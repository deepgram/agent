{
  "name": "@deepgram/agent-widget",
  "version": "0.0.0",
  "description": "Self-contained CDN widget for Deepgram Voice Agent — no framework required",
  "type": "module",
  "main": "dist/widget.umd.js",
  "module": "dist/widget.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/widget.es.js",
      "require": "./dist/widget.umd.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "dev": "vite",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@deepgram/agent": "workspace:*",
    "@deepgram/react": "file:../../../react/packages/react",
    "@deepgram/ui": "file:../../../ui/packages/ui",
    "preact": "10.29.1",
    "sugar-high": "1.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.2",
    "@testing-library/preact": "3.2.4",
    "@types/node": "22.15.3",
    "@vitejs/plugin-react": "6.0.1",
    "eventemitter3": "5.0.4",
    "happy-dom": "20.8.9",
    "tailwindcss": "4.2.2",
    "terser": "5.46.1",
    "typescript": "6.0.2",
    "vite": "8.0.5",
    "vite-plugin-css-injected-by-js": "4.0.1",
    "vite-plugin-dts": "4.5.4"
  },
  "license": "MIT"
}
