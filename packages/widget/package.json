{
  "name": "@deepgram/agents-widget",
  "version": "0.0.0",
  "description": "Self-contained CDN widget for Deepgram Voice Agent — no framework required",
  "type": "module",
  "main": "dist/widget.umd.js",
  "module": "dist/widget.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/widget.es.js",
      "require": "./dist/widget.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deepgram/agent.git",
    "directory": "packages/widget"
  },
  "homepage": "https://github.com/deepgram/agent/tree/main/packages/widget#readme",
  "bugs": {
    "url": "https://github.com/deepgram/agent/issues"
  },
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "dev": "vite",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@deepgram/agents": "workspace:*",
    "@deepgram/react": "^0.1.0",
    "@deepgram/ui": "^0.1.0",
    "preact": "10.29.1",
    "sugar-high": "1.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.4",
    "@testing-library/preact": "3.2.4",
    "@types/node": "25.6.0",
    "@vitejs/plugin-react": "6.0.1",
    "eventemitter3": "5.0.4",
    "happy-dom": "20.9.0",
    "tailwindcss": "4.2.4",
    "terser": "5.46.2",
    "typescript": "6.0.2",
    "vite": "8.0.10",
    "vite-plugin-css-injected-by-js": "4.0.1",
    "vite-plugin-dts": "4.5.4"
  },
  "license": "MIT"
}
