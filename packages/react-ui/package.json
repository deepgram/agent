{
  "name": "@deepgram/agent-react-ui",
  "version": "0.0.1",
  "description": "Pre-built, styled React components for Deepgram Voice Agent — fully customizable via CSS variables",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "dev": "vite build --watch",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@deepgram/agent-react": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eventemitter3": "5.0.4",
    "happy-dom": "20.8.9",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "terser": "5.46.1",
    "typescript": "5.9.3",
    "vite": "8.0.8",
    "vite-plugin-dts": "4.5.4"
  },
  "license": "MIT"
}
