{
  "name": "@deepgram/agent-client",
  "version": "0.0.1",
  "description": "Voice + chat agent widget for Deepgram-powered sites",
  "type": "module",
  "main": "dist/deepgram-agent.umd.js",
  "module": "dist/deepgram-agent.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/deepgram-agent.es.js",
      "require": "./dist/deepgram-agent.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "@lukeocodes/composite-voice": "^0.1.1",
    "preact": "^10.29.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sugar-high": "^0.9.5"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "terser": "^5.46.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-dts": "^4.3.0"
  },
  "license": "MIT"
}
