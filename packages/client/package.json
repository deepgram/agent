{
  "name": "@deepgram/console-agent-client",
  "version": "0.0.1",
  "description": "Voice + chat agent widget for the Deepgram Console UI",
  "type": "module",
  "main": "dist/deepgram-console-agent.umd.js",
  "module": "dist/deepgram-console-agent.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/deepgram-console-agent.es.js",
      "require": "./dist/deepgram-console-agent.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@lukeocodes/composite-voice": "^0.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-dts": "^4.3.0"
  },
  "license": "MIT"
}
