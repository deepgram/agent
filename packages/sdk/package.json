{
  "name": "@deepgram/agents",
  "version": "0.1.1",
  "description": "Deepgram Voice Agent SDK — browser/Node WebSocket client with microphone, audio playback, and VAD",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deepgram/agent.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/deepgram/agent/tree/main/packages/sdk#readme",
  "bugs": {
    "url": "https://github.com/deepgram/agent/issues"
  },
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "dev": "vite build --watch",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@deepgram/sdk": "5.1.0",
    "eventemitter3": "5.0.4"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "happy-dom": "20.9.0",
    "terser": "5.46.2",
    "typescript": "6.0.2",
    "vite": "8.0.10",
    "vite-plugin-dts": "5.0.0"
  },
  "license": "MIT"
}
