{
  "name": "@deepgram/agents",
  "version": "0.0.0",
  "description": "Deepgram Voice Agent SDK — browser/Node WebSocket client with microphone, audio playback, and VAD",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "dev": "vite build --watch",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@deepgram/sdk": "5.0.0",
    "eventemitter3": "5.0.4"
  },
  "devDependencies": {
    "@types/node": "22.15.3",
    "happy-dom": "20.8.9",
    "terser": "5.46.1",
    "typescript": "5.9.3",
    "vite": "8.0.5",
    "vite-plugin-dts": "4.5.4"
  },
  "license": "MIT"
}
